//                                                         ▀▀▀   █   ▀▀▀   █   ▀▀▀   ▀   ▀▀▀
//                                                               █      ▄▄▄█▄▄▄    █   █
//                                                               ▀      █  █  █     █▄█
//                                                             ▀▀▀▀▀    █  █  █      ▀
//                                                                      ▀  ▀  ▀
//
// ▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄

#define ZMK_POINTING_DEFAULT_MOVE_VAL 2000
#define ZMK_POINTING_DEFAULT_SCRL_VAL 30

#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/pointing.h>

#define mouse 6

&mmv {
    time-to-max-speed-ms = <300>;
    acceleration-exponent = <1>;
};

&msc {
    time-to-max-speed-ms = <300>;
    acceleration-exponent = <1>;
};

&mt {
    flavor = "tap-preferred";
    tapping-term-ms = <200>;
};

/ {
    behaviors {
        hml: home_row_mod_left {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "balanced";
            require-prior-idle-ms = <150>;
            tapping-term-ms = <280>;
            quick-tap-ms = <175>;
            bindings = <&kp>, <&kp>;

            hold-trigger-key-positions = <5 15 26 16 6 7 17 28 27 8 18 29 9 19 30>;
            hold-trigger-on-release;
        };

        hmr: home_row_mod_right {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "balanced";
            require-prior-idle-ms = <150>;
            tapping-term-ms = <280>;
            quick-tap-ms = <175>;
            bindings = <&kp>, <&kp>;

            hold-trigger-key-positions = <0 0 1 4 10 11 12 13 14 21 22 23 24 25 2 3>;
            hold-trigger-on-release;
        };

        eq_td: eq_td {
            compatible = "zmk,behavior-tap-dance";
            label = "EQ_TD";
            #binding-cells = <0>;
            tapping-term-ms = <300>;
            bindings = <&kp EQUAL>, <&eq>;
        };

        minus_td: minus_td {
            compatible = "zmk,behavior-tap-dance";
            label = "MINUS_TD";
            #binding-cells = <0>;
            tapping-term-ms = <300>;
            bindings = <&mt LEFT_SHIFT MINUS>, <&minus>;
        };

        plus_td: plus_td {
            compatible = "zmk,behavior-tap-dance";
            label = "PLUS_TD";
            #binding-cells = <0>;
            tapping-term-ms = <300>;
            bindings = <&kp PLUS>, <&plus>;
        };

        div_td: div_td {
            compatible = "zmk,behavior-tap-dance";
            label = "DIV_TD";
            #binding-cells = <0>;
            tapping-term-ms = <300>;
            bindings = <&kp SLASH>, <&div>;
        };

        mult_td: mult_td {
            compatible = "zmk,behavior-tap-dance";
            label = "MULT_TD";
            #binding-cells = <0>;
            tapping-term-ms = <300>;
            bindings = <&kp ASTRK>, <&mult>;
        };

        paren_td: paren_td {
            compatible = "zmk,behavior-tap-dance";
            label = "PAREN_TD";
            #binding-cells = <0>;
            tapping-term-ms = <300>;
            bindings = <&kp LEFT_PARENTHESIS>, <&paren>;
        };

        bracket_td: bracket_td {
            compatible = "zmk,behavior-tap-dance";
            label = "BRACKET_TD";
            #binding-cells = <0>;
            tapping-term-ms = <300>;
            bindings = <&kp LEFT_BRACKET>, <&brackets>;
        };

        curly_td: curly_td {
            compatible = "zmk,behavior-tap-dance";
            label = "CURLY_TD";
            #binding-cells = <0>;
            tapping-term-ms = <300>;
            bindings = <&kp LEFT_BRACE>, <&curly_braces>;
        };

        apos_quote: apos_quote {
            compatible = "zmk,behavior-mod-morph";
            label = "APOS_QUOTE";
            bindings = <&apos_td>, <&kp DOUBLE_QUOTES>;

            #binding-cells = <0>;
            mods = <(MOD_LSFT|MOD_RSFT)>;
        };

        apos_td: apos_td {
            compatible = "zmk,behavior-tap-dance";
            label = "APOS_TD";
            #binding-cells = <0>;
            tapping-term-ms = <300>;
            bindings = <&apos_single>, <&apos_pair>, <&quote_pair>;
        };

        grave_td: grave_td {
            compatible = "zmk,behavior-tap-dance";
            label = "GRAVE_TD";
            #binding-cells = <0>;
            tapping-term-ms = <300>;
            bindings = <&kp GRAVE>, <&backtick_pair>, <&triple_grave>;
        };

        pipe_td: pipe_td {
            compatible = "zmk,behavior-tap-dance";
            label = "PIPE_TD";
            #binding-cells = <0>;
            tapping-term-ms = <300>;
            bindings = <&kp PIPE>, <&pipe>, <&double_or>;
        };

        amp_td: amp_td {
            compatible = "zmk,behavior-tap-dance";
            label = "AMP_TD";
            #binding-cells = <0>;
            tapping-term-ms = <300>;
            bindings = <&kp AMPS>, <&amp>, <&and>;
        };

        tilde_td: tilde_td {
            compatible = "zmk,behavior-tap-dance";
            label = "TILDE_TD";
            #binding-cells = <0>;
            tapping-term-ms = <300>;
            bindings = <&kp TILDE>, <&tilde_slash>, <&tilde_slash_dot>;
        };
    };
};

/ {
    combos {
        compatible = "zmk,combos";

        left_esc {
            bindings = <&kp ESCAPE>;
            key-positions = <1 0>;
        };

        enter {
            bindings = <&kp RET>;
            key-positions = <16 17 18>;
            timeout-ms = <100>;
        };

        tab {
            bindings = <&kp TAB>;
            key-positions = <10 11>;
        };

        r_word {
            bindings = <&kp LA(RIGHT)>;
            key-positions = <18 17>;
            layers = <0 2 3>;
        };

        backspace {
            bindings = <&kp BACKSPACE>;
            key-positions = <18 19>;
            timeout-ms = <100>;
        };

        l_word {
            bindings = <&kp LA(LEFT)>;
            key-positions = <17 16>;
            layers = <0 2 3>;
            timeout-ms = <100>;
        };

        backspace2 {
            bindings = <&kp BACKSPACE>;
            key-positions = <16 35>;
        };

        backspace3 {
            bindings = <&kp BACKSPACE>;
            key-positions = <13 34>;
        };

        del_word {
            bindings = <&kp LA(BACKSPACE)>;
            key-positions = <35 16 17>;
            layers = <0 2>;
        };

        del_word_fw {
            bindings = <&kp LA(DELETE)>;
            key-positions = <17 18 35>;
            layers = <0 2>;
        };

        bt_clear {
            bindings = <&bt BT_CLR>;
            key-positions = <34 20>;
            layers = <7>;
        };

        bt_0 {
            bindings = <&bt BT_SEL 0>;
            key-positions = <34 21>;
            layers = <8>;
        };

        bt_1 {
            bindings = <&bt BT_SEL 1>;
            key-positions = <34 10>;
            layers = <7>;
        };

        bt_2 {
            bindings = <&bt BT_SEL 2>;
            key-positions = <34 0>;
            layers = <7>;
        };

        reset {
            bindings = <&sys_reset>;
            key-positions = <34 0 10 21>;
            layers = <7>;
        };

        language_switch {
            bindings = <&kp LC(SPACE)>;
            key-positions = <34 35>;
            timeout-ms = <300>;
            layers = <0 2>;
        };

        caps_word {
            bindings = <&caps_word>;
            key-positions = <10 19>;
            timeout-ms = <100>;
        };

        mouse_layer {
            bindings = <&mo 6>;
            key-positions = <12 13>;
            slow-release;
            layers = <0 2>;
        };
    };

    macros {
        personal_email: personal_email {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp M &kp U &kp R &kp Z &kp N4 &kp N2 &kp AT &kp G &kp M &kp A &kp I &kp L &kp DOT &kp C &kp O &kp M>;
            label = "PERSONAL_EMAIL";
        };

        work_email: work_email {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp I &kp L &kp I &kp A &kp DOT &kp M &kp U &kp R &kp Z &kp I &kp N &kp O &kp V &kp AT &kp R &kp E &kp V &kp O &kp L &kp U &kp T &kp DOT &kp C &kp O &kp M>;
            label = "WORK_EMAIL";
        };

        thinking_face: thinking_face {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp COLON &kp T &kp H &kp I &kp N &kp K &kp I &kp N &kp G &kp UNDER &kp F &kp A &kp C &kp E &kp COLON>;
            label = "THINKING_FACE";
        };

        name: name {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LS(I) &kp L &kp I &kp A>;
            label = "NAME";
        };

        last_name: last_name {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LS(M) &kp U &kp R &kp Z &kp I &kp N &kp O &kp V>;
            label = "LAST_NAME";
        };

        eq: eq {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp SPACE &kp EQUAL &kp SPACE>;
            label = "EQ";
        };

        mult: mult {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp SPACE &kp STAR &kp SPACE>;
            label = "MULT";
        };

        div: div {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp SPACE &kp FSLH &kp SPACE>;
            label = "DIV";
        };

        minus: minus {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp SPACE &kp MINUS &kp SPACE>;
            label = "MINUS";
        };

        plus: plus {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp SPACE &kp PLUS &kp SPACE>;
            label = "PLUS";
        };

        paren: paren {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LPAR &kp RPAR &kp LEFT>;
            label = "PAREN";
        };

        brackets: brackets {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LBKT &kp RBKT &kp LEFT>;
            label = "BRACKETS";
        };

        curly_braces: curly_braces {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LBRC &kp RBRC &kp LEFT>;
            label = "CURLY_BRACES";
        };

        apos_single: apos_single {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp SQT>;
            label = "APOS_SINGLE";
        };

        apos_pair: apos_pair {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp SQT &kp SQT &kp LEFT>;
            label = "APOS_PAIR";
        };

        quote_pair: quote_pair {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp DOUBLE_QUOTES &kp DOUBLE_QUOTES &kp LEFT>;
            label = "QUOTE_PAIR";
        };

        backtick_pair: backtick_pair {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp GRAVE &kp GRAVE &kp LEFT>;
            label = "BACKTICK_PAIR";
        };

        triple_grave: triple_grave {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp GRAVE &kp GRAVE &kp GRAVE &kp LS(RET) &kp LS(RET) &kp GRAVE &kp GRAVE &kp GRAVE &kp UP_ARROW>;
            label = "TRIPLE_GRAVE";
        };

        pipe: pipe {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp SPACE &kp PIPE &kp SPACE>;
            label = "PIPE";
        };

        and: and {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp SPACE &kp A &kp N &kp D &kp SPACE>;
            label = "AND";
        };

        amp: amp {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp SPACE &kp AMPS &kp AMPS &kp SPACE>;
            label = "AMP";
        };

        tilde_slash: tilde_slash {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp TILDE &kp FSLH>;
            label = "TILDE_SLASH";
        };

        tilde_slash_dot: tilde_slash_dot {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp TILDE &kp FSLH &kp DOT>;
            label = "TILDE_SLASH_DOT";
        };

        double_or: double_or {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp SPACE &kp PIPE &kp PIPE &kp SPACE>;
            label = "DOUBLE_OR";
        };
    };

    keymap {
        compatible = "zmk,keymap";

        base {
            bindings = <
       &kp Q              &kp W         &kp E            &kp R            &kp T          &kp Y        &kp U            &kp I             &kp O         &kp P
       &hml LEFT_SHIFT A  &hml LCTRL S  &hml LEFT_ALT D  &hml LEFT_GUI F  &kp G          &kp H        &hmr LEFT_GUI J  &hmr RIGHT_ALT K  &hmr RCTRL L  &hmr RIGHT_SHIFT SEMI
&none  &kp Z              &kp X         &kp C            &kp V            &kp B          &kp N        &kp M            &kp COMMA         &kp DOT       &apos_quote            &none
                                        &none            &mo 3            &lt 4 SPACE    &lt 5 SPACE  &mo 1            &mo 7
            >;
        };

        rus {
            bindings = <
        &trans  &kp LS(N7)  &trans  &trans  &kp GRAVE    &trans  &trans             &trans         &trans     &kp LEFT_BRACKET
        &trans  &trans      &trans  &trans  &trans       &trans  &trans             &trans         &trans     &kp APOS
&trans  &trans  &trans      &trans  &trans  &trans       &trans  &kp RIGHT_BRACKET  &kp LS(SLASH)  &kp SLASH  &trans            &trans
                            &trans  &trans  &trans       &trans  &trans             &trans
            >;
        };

        colemak {
            bindings = <
       &kp Q              &kp W         &kp F            &kp P            &kp B          &kp J        &kp L            &kp U             &kp Y         &kp SEMI
       &hml LEFT_SHIFT A  &hml LCTRL R  &hml LEFT_ALT S  &hml LEFT_GUI T  &kp G          &kp M        &hmr LEFT_GUI N  &hmr RIGHT_ALT E  &hmr RCTRL I  &hmr RIGHT_SHIFT O
&none  &kp Z              &kp X         &kp C            &kp D            &kp V          &kp K        &kp H            &kp COMMA         &kp DOT       &apos_quote            &none
                                        &none            &mo 3            &lt 4 SPACE    &lt 5 SPACE  &mo 1            &mo 7
            >;
        };

        nav {
            bindings = <
       &kp LG(NUMBER_1)  &kp LG(NUMBER_2)  &kp LG(NUMBER_3)      &kp LG(NUMBER_4)       &kp LG(N5)    &none     &kp PAGE_DOWN             &kp PAGE_UP                &none      &none
       &kp LEFT_SHIFT    &kp LC(UP_ARROW)  &kp LC(LEFT_ARROW)    &kp LC(RIGHT)          &none         &kp LEFT  &kp DOWN                  &kp UP                     &kp RIGHT  &none
&none  &none             &none             &kp LG(LEFT_BRACKET)  &kp LG(RIGHT_BRACKET)  &none         &none     &kp LG(LS(LEFT_BRACKET))  &kp LG(LS(RIGHT_BRACKET))  &none      &none  &none
                                           &none                 &none                  &none         &none     &none                     &none
            >;
        };

        sym {
            bindings = <
       &kp EXCL   &kp QUESTION  &kp AT         &kp HASH  &kp DOLLAR    &tilde_td    &kp N7  &kp N8  &kp N9  &kp RPAR
       &minus_td  &plus_td      &div_td        &mult_td  &eq_td        &grave_td    &kp N4  &kp N5  &kp N6  &paren_td
&none  &kp UNDER  &kp PERCENT   &kp BACKSLASH  &amp_td   &pipe_td      &kp N0       &kp N1  &kp N2  &kp N3  &kp SLASH  &none
                                &none          &none     &none         &lt 5 SPACE  &mo 7   &none
            >;
        };

        sym_add {
            bindings = <
       &kp EXCL   &kp QUESTION  &kp AT         &kp HASH  &kp DOLLAR     &kp CARET  &none        &none              &none  &none
       &minus_td  &plus_td      &div_td        &mult_td  &eq_td         &none      &bracket_td  &kp RIGHT_BRACKET  &none  &none
&none  &kp UNDER  &kp PERCENT   &kp BACKSLASH  &amp_td   &pipe_td       &none      &curly_td    &kp RIGHT_BRACE    &none  &none  &none
                                &none          &none     &lt 4 SPACE    &none      &mo 7        &none
            >;
        };

        mouse {
            bindings = <
       &none           &none  &none   &none   &none           &msc SCRL_RIGHT  &msc SCRL_UP              &msc SCRL_DOWN             &msc SCRL_LEFT   &none
       &kp LEFT_SHIFT  &none  &none   &none   &none           &mmv MOVE_LEFT   &mmv MOVE_DOWN            &mmv MOVE_UP               &mmv MOVE_RIGHT  &none
&none  &none           &none  &none   &none   &none           &none            &kp LG(LS(LEFT_BRACKET))  &kp LG(LS(RIGHT_BRACKET))  &none            &none  &none
                              &trans  &trans  &kp LEFT_GUI    &mkp MB1         &mkp MB2                  &none
            >;
        };

        media {
            bindings = <
       &tog 2                &none              &kp LS(LG(NUMBER_3))  &kp LG(LS(NUMBER_4))   &none    &none             &kp C_BRIGHTNESS_DEC  &kp C_BRIGHTNESS_INC  &none       &none
       &kp LG(LA(LC(LEFT)))  &kp LA(LG(LC(F)))  &kp LG(LC(F))         &kp LA(LG(LC(RIGHT)))  &none    &kp C_PLAY_PAUSE  &kp C_VOL_DN          &kp C_VOLUME_UP       &kp K_MUTE  &none
&none  &none                 &none              &none                 &none                  &none    &none             &none                 &none                 &none       &none  &none
                                                &none                 &none                  &none    &none             &none                 &none
            >;
        };

        macros {
            bindings = <
       &none  &none       &none            &none        &none    &none  &none  &none  &none  &none
       &name  &last_name  &personal_email  &work_email  &none    &none  &none  &none  &none  &none
&none  &none  &none       &none            &none        &none    &none  &none  &none  &none  &none  &none
                          &none            &none        &none    &none  &none  &none
            >;
        };
    };
};
